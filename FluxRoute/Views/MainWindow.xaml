<Window x:Class="FluxRoute.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRoute"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontSize" Value="13"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#AAAAAA"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand" Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#2D2D30" BorderBrush="#3E3E42"
                                        BorderThickness="1" CornerRadius="4" Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Margin="15,0">
                <TextBlock FontSize="22" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center">
                    <Run Text="◇ FluxRoute"/>
                    <Run Text="{Binding AppVersion, Mode=OneWay}" FontSize="12" Foreground="#888888"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-6,0">
                    <Button Width="34" Height="34" Margin="2,0"
                            Command="{Binding OpenAboutCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="#AAAAAA" x:Name="Ico"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                        <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Width="34" Height="34" Margin="2,0"
                            Click="MinimizeButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                    <TextBlock Text="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="#AAAAAA" x:Name="Ico"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                        <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Width="34" Height="34" Margin="2,0"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                    <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="#AAAAAA" x:Name="Ico"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                        <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,20">

                <!-- Big Action Button -->
                <Button Height="70" FontSize="20" FontWeight="Bold"
                        Command="{Binding MainActionCommand}"
                        Margin="0,0,0,15"
                        Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="#27AE60"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Background" Value="#C0392B"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="{Binding MainActionButtonText}" FontSize="20" FontWeight="Bold"/>
                </Button>

                <!-- Active status label -->
                <TextBlock Text="Защита активна ✓"
                           Foreground="#4CAF50" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,25"
                           Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisConverter}}"/>

                <!-- Engine download progress -->
                <Border Background="#2A2000" BorderBrush="#5A4800" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,15"
                        Visibility="{Binding IsDownloadingEngine, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="⬇️ Первый запуск — скачиваем Flowseal..."
                                   Foreground="#FFD700" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding EngineDownloadStatus}"
                                   Foreground="#CCAA00" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Rectangle Height="1" Fill="#3E3E42" Margin="0,0,0,20"/>

                <!-- Stats Block -->
                <StackPanel Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🔹" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Профиль: " Foreground="#AAAAAA" FontSize="15" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  MinWidth="180" VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="13"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Width="30" Height="30" Margin="6,0,0,0" VerticalAlignment="Center"
                                Command="{Binding RefreshProfilesCommand}" ToolTip="Обновить список профилей" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#2D2D30" CornerRadius="6"
                                            BorderBrush="#3E3E42" BorderThickness="1">
                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="#AAAAAA" x:Name="Ico"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#4FC3F7"/>
                                            <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🔹" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Uptime: " Foreground="#AAAAAA" FontSize="15"/>
                        <TextBlock Text="{Binding UptimeText}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔹" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="PID: " Foreground="#AAAAAA" FontSize="15"/>
                        <TextBlock Text="{Binding PidText}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Footer Actions -->
                <Grid Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="#AAAAAA" BorderThickness="0"
                            FontSize="13" Cursor="Hand"
                            Command="{Binding ToggleLogsCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="▼ Показать логи"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLogsVisible}" Value="True">
                                        <Setter Property="Content" Value="▲ Скрыть логи"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="1" HorizontalAlignment="Right"
                            Background="#2D2D30" Foreground="White" BorderThickness="0"
                            Padding="15,8" FontSize="13" Cursor="Hand"
                            Command="{Binding ToggleSettingsCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="⚙ Настройки"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3E3E42"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Collapsible Logs -->
                <ItemsControl ItemsSource="{Binding RecentLogs}"
                              Margin="0,15,0,0"
                              Visibility="{Binding IsLogsVisible, Converter={StaticResource BoolToVisConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#888888"
                                       Margin="0,4" FontFamily="Consolas" FontSize="11"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

            </Grid>
            </Border>
        </Window>
