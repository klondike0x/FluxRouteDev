<Window x:Class="FluxRoute.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки FluxRoute"
        Height="600" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Tab style -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}"
                                Background="Transparent" BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#4FC3F7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Value style -->
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark button -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Accent button -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#0078D4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1084D8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Green button -->
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2ECC71"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Red button -->
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#C0392B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontSize" Value="13"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#AAAAAA"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand" Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#2D2D30" BorderBrush="#3E3E42"
                                        BorderThickness="1" CornerRadius="4" Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Separator -->
        <Style x:Key="Sep" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill" Value="#3E3E42"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <!-- Score row -->
        <Style x:Key="ScoreRow" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Margin="16,0">
                <TextBlock Text="⚙️ Настройки FluxRoute" FontSize="16" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Width="34" Height="34" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="#AAAAAA" x:Name="Ico"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                    <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    TabStripPlacement="Top">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="#252526"/>
                </Style>
            </TabControl.Resources>

            <!-- ═══ ОРКЕСТРАТОР ═══ -->
            <TabItem Header="🤖 Оркестратор">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,12">

                        <TextBlock Style="{StaticResource SectionHeader}" Text="УПРАВЛЕНИЕ"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button MinWidth="160" Margin="0,0,10,0"
                                    Command="{Binding ToggleOrchestratorCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                        <Setter Property="Content" Value="▶ Запустить оркестратор"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrchestratorRunning}" Value="True">
                                                <Setter Property="Content" Value="⏹ Остановить оркестратор"/>
                                                <Setter Property="Background" Value="#C0392B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="🔍 Проверить сейчас" Style="{StaticResource DarkButton}"
                                    Command="{Binding CheckNowCommand}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Style="{StaticResource Label}" Text="Интервал проверки (мин): " Margin="0,0,8,0"/>
                            <TextBox Text="{Binding OrchestratorInterval, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" Height="28"
                                     Background="#2D2D30" Foreground="White"
                                     BorderBrush="#3E3E42" FontSize="13"
                                     Padding="6,4" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource Label}" Text="Следующая проверка: " Margin="0,0,8,0"/>
                            <TextBlock Style="{StaticResource Value}" Text="{Binding OrchestratorNextCheck}"/>
                        </StackPanel>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="САЙТЫ ДЛЯ ПРОВЕРКИ"/>
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox Content="YouTube" IsChecked="{Binding SiteYouTube}" Margin="0,4,16,4"/>
                            <CheckBox Content="Discord" IsChecked="{Binding SiteDiscord}" Margin="0,4,16,4"/>
                            <CheckBox Content="Google" IsChecked="{Binding SiteGoogle}" Margin="0,4,16,4"/>
                            <CheckBox Content="Twitch" IsChecked="{Binding SiteTwitch}" Margin="0,4,16,4"/>
                            <CheckBox Content="Instagram" IsChecked="{Binding SiteInstagram}" Margin="0,4,16,4"/>
                        </WrapPanel>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="РЕЙТИНГ ПРОФИЛЕЙ"/>
                        <Button HorizontalAlignment="Left" Margin="0,0,0,10"
                                Command="{Binding ScanProfilesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                    <Setter Property="Content" Value="📊 Сканировать все профили"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="⏳ Сканирование..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="{Binding ScanProgressText}" Foreground="#4FC3F7"
                                   FontSize="12" Margin="0,0,0,8"
                                   Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}"/>

                        <ItemsControl ItemsSource="{Binding ProfileScores}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ScoreRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ScoreText}"
                                                       Foreground="#4FC3F7" FontSize="13" FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="🗑 Очистить лог оркестратора" Style="{StaticResource DarkButton}"
                                HorizontalAlignment="Left" Margin="0,10,0,0"
                                Command="{Binding ClearOrchestratorLogsCommand}"/>

                        <!-- Orchestrator log -->
                        <Border Background="#141414" CornerRadius="6" Margin="0,8,0,0" MaxHeight="120">
                            <ItemsControl ItemsSource="{Binding OrchestratorLogs}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#888888"
                                                   FontFamily="Consolas" FontSize="11" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ ОБНОВЛЕНИЯ ═══ -->
            <TabItem Header="⬆️ Обновления">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,12">

                        <TextBlock Style="{StaticResource SectionHeader}" Text="FLOWSEAL ZAPRET"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="Текущая версия:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding CurrentEngineVersion}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="Статус:"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding UpdateStatus}"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button MinWidth="120" Margin="0,0,10,0"
                                    Command="{Binding CheckUpdatesCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                        <Setter Property="Content" Value="🔍 Проверить"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Content" Value="⏳ Обновление..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button MinWidth="120"
                                    Command="{Binding InstallUpdatesCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Setter Property="Content" Value="⬆️ Обновить"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <CheckBox Content="Автоматически проверять при запуске"
                                  IsChecked="{Binding AutoUpdateEnabled}" Margin="0,0,0,12"/>

                        <Border Background="#2A2000" BorderBrush="#5A4800" BorderThickness="1"
                                CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFD700"
                                       Text="⚠️ При обновлении winws.exe будет остановлен. После установки нужно заново запустить профиль."/>
                        </Border>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="ЛОГ ОБНОВЛЕНИЯ"/>
                        <Border Background="#141414" CornerRadius="6" MaxHeight="160">
                            <ItemsControl ItemsSource="{Binding UpdateLogs}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#888888"
                                                   FontFamily="Consolas" FontSize="11" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ СЕРВИС ═══ -->
            <TabItem Header="🛠 Сервис">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,12">

                        <TextBlock Style="{StaticResource SectionHeader}" Text="GAME FILTER"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Style="{StaticResource Label}" Text="Статус: " Margin="0,0,8,0"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="❌ Выключен"/>
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GameFilterEnabled}" Value="True">
                                                <Setter Property="Text" Value="✅ Включён"/>
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Foreground="#777777" FontSize="11" Margin="0,2,0,8"
                                   Text="Расширяет диапазон портов (1024-65535) для обхода в играх. Выберите протокол и нажмите кнопку. Перезапустите zapret после изменения."
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Command="{Binding ToggleGameFilterCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                        <Setter Property="Content" Value="🎮 Включить Game Filter"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GameFilterEnabled}" Value="True">
                                                <Setter Property="Content" Value="🎮 Выключить Game Filter"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <ComboBox ItemsSource="{Binding GameFilterProtocols}"
                                      SelectedItem="{Binding GameFilterProtocol}"
                                      Width="140" Margin="10,0,0,0"/>
                        </StackPanel>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="IPSET FILTER"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Style="{StaticResource Label}" Text="Режим: " Margin="0,0,8,0"/>
                            <TextBlock Style="{StaticResource Value}" Text="{Binding IpSetMode}"/>
                        </StackPanel>
                        <TextBlock Foreground="#777777" FontSize="11" Margin="0,2,0,8" TextWrapping="Wrap"
                                   Text="loaded — фильтрация по списку IP · none — фильтрация отключена · any — все адреса"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔄 Переключить режим" Style="{StaticResource DarkButton}"
                                    Margin="0,0,10,0" Command="{Binding CycleIpSetModeCommand}"/>
                            <Button Content="⬇️ Обновить IPSet" Margin="0,0,0,0"
                                    Command="{Binding UpdateIpSetListCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServiceBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="HOSTS FILE"/>
                        <TextBlock Foreground="#777777" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Проверяет и обновляет системный hosts файл. Если нужно обновление — откроются оба файла для ручного копирования."/>
                        <Button Content="🔍 Проверить / обновить Hosts"
                                Command="{Binding UpdateHostsFileCommand}" HorizontalAlignment="Left">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServiceBusy}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="СЛУЖБА ZAPRET"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Style="{StaticResource Label}" Text="Статус: " Margin="0,0,8,0"/>
                            <TextBlock Style="{StaticResource Value}" Text="{Binding ZapretServiceStatus}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="📦 Установить службу" Style="{StaticResource GreenButton}"
                                    Margin="0,0,10,0" Command="{Binding InstallZapretServiceCommand}"/>
                            <Button Content="⏹ Принудительно остановить" Style="{StaticResource RedButton}"
                                    Margin="0,0,10,0" Command="{Binding ForceStopZapretServiceCommand}"/>
                            <Button Content="🔄" Style="{StaticResource DarkButton}"
                                    Command="{Binding RefreshServiceInfoCommand}"/>
                        </StackPanel>

                        <Border Background="#2A2000" BorderBrush="#5A4800" BorderThickness="1"
                                CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFD700"
                                       Text="⚠️ Установка службы запускает service.bat с правами администратора. Служба запускает zapret автоматически при загрузке Windows (без GUI)."/>
                        </Border>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="ЛОГ СЕРВИСА"/>
                        <Border Background="#141414" CornerRadius="6" MaxHeight="150">
                            <ItemsControl ItemsSource="{Binding ServiceLogs}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#888888"
                                                   FontFamily="Consolas" FontSize="11" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ ДИАГНОСТИКА ═══ -->
            <TabItem Header="🔧 Диагностика">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,12">

                        <TextBlock Style="{StaticResource SectionHeader}" Text="СИСТЕМНЫЕ НАСТРОЙКИ" Margin="0,0,0,8"/>

                        <CheckBox Content="Запускать FluxRoute при входе в Windows"
                                  IsChecked="{Binding AutoStartEnabled}" Margin="0,4,0,4"/>

                        <CheckBox Content="Показывать предупреждение при смене профиля"
                                  IsChecked="{Binding ShowProfileSwitchWarning}" Margin="0,4,0,12"/>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="КОМПОНЕНТЫ"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="Права администратора:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding AdminText}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="engine/:"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding EngineText}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Label}" Text="winws.exe:"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding WinwsText}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Label}" Text="WinDivert.dll:"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding WinDivertDllText}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource Label}" Text="WinDivert.sys:"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding WinDivertDriverText}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource Label}" Text="Версия приложения:"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource Value}" Text="{Binding AppVersion}"/>
                        </Grid>

                        <WrapPanel>
                            <Button Content="🔄 Обновить" Style="{StaticResource DarkButton}"
                                    Margin="0,0,8,8" Command="{Binding RefreshProfilesCommand}"/>
                            <Button Content="📋 Скопировать" Style="{StaticResource DarkButton}"
                                    Margin="0,0,8,8"
                                    Command="{Binding CopyDiagnosticsCommand}"/>
                            <Button Content="📄 Экспорт логов" Style="{StaticResource DarkButton}"
                                    Margin="0,0,8,8"
                                    Command="{Binding ExportLogsCommand}"/>
                        </WrapPanel>

                        <Rectangle Style="{StaticResource Sep}"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="СИСТЕМНЫЙ ЛОГ"/>
                        <Border Background="#141414" CornerRadius="6" MaxHeight="200">
                            <ItemsControl ItemsSource="{Binding Logs}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#888888"
                                                   FontFamily="Consolas" FontSize="11" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
    </Border>
</Window>
